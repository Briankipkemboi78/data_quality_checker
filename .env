# ── Local Development Environment Variables ────────────────────────────────────
# This file is for LOCAL development only.
# NEVER commit this file to version control — add .env to your .gitignore.
#
# On Azure App Service, set these under:
#   Configuration → Application Settings (not via this file)

# ── Authentication ─────────────────────────────────────────────────────────────
# Set to "false" locally so the Azure AD gate is bypassed.
# Set to "true" in Azure App Service settings for production.
REQUIRE_AUTH=false
AUTH_PROVIDER=azure_ad

# Comma-separated list of allowed email domains (leave blank to allow all)
# Example: ALLOWED_EMAIL_DOMAINS=company.com,partner.com
ALLOWED_EMAIL_DOMAINS=

# External identity provider settings (only needed if AUTH_PROVIDER=external)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── File Handling ──────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── Concurrency ────────────────────────────────────────────────────────────────
MAX_CONCURRENT_CHECKS=20

# ── Logging ────────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Azure Application Insights key (leave blank locally)
APPINSIGHTS_INSTRUMENTATIONKEY=

# ── Hosting ────────────────────────────────────────────────────────────────────
HOSTING_PLATFORM=azure_app_service
AZURE_REGION=eastus

# Comma-separated allowed CORS origins (managed at Azure level, not Streamlit)
ALLOWED_ORIGINS=
